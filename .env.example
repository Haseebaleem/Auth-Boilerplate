# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL — apne local pe jo bhi setup ho)
DATABASE_URL="postgresql://username:password@localhost:5432/auth_boilerplate?schema=public"

# JWT Secrets (production mein strong random strings use karna)
JWT_ACCESS_SECRET="generate-a-strong-secret"
JWT_REFRESH_SECRET="generate-another-strong-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="2d"

# Cookie
COOKIE_DOMAIN=localhost